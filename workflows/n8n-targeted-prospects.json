    {
      "parameters": {
        "jsCode": "const raw       = $input.first().json['Domains'] || '';\nconst dept      = $input.first().json['Department'] || 'sales';\nconst seniority = $input.first().json['Seniority']  || 'director';\nconst maxCount  = parseInt($input.first().json['Max results per domain'] || '10');\n\nreturn raw.split('\\n').map(d => d.trim()).filter(d => d)\n  .map(domain => ({ json: { domain, department: dept, seniority, employee_count: maxCount } }));"
      },
