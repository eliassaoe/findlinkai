        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"type\": \"company_domain_to_employees\",\n  \"input_data\": \"{{ $json.domain }}\",\n  \"department\": \"{{ $json.department }}\",\n  \"seniority\": \"{{ $json.seniority }}\",\n  \"employee_count\": {{ $json.employee_count }}\n}",
        "options": {
          "timeout": 120000
